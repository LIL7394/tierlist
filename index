<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Tierlist</title>
  <link rel="stylesheet" href="style.css">
  <!-- Firebase scripts -->
  <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app.js"></script>
  <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database.js"></script>
</head>
<body>
  <h1>My Tierlist</h1>
  
  <div id="tier-container">
    <div>S Tier: <input id="s-tier" placeholder="Add names..."></div>
    <div>A Tier: <input id="a-tier" placeholder="Add names..."></div>
    <div>B Tier: <input id="b-tier" placeholder="Add names..."></div>
  </div>

  <button onclick="saveTierList()">Save</button>
  <button onclick="loadTierList()">Load</button>

  <script src="script.js"></script>
</body>
</html>
